# Ruta base donde se despliega el frontend
# Si esta en la raiz del dominio: VITE_BASE=/
# Si esta en un subdirectorio: VITE_BASE=/mimi/
# IMPORTANTE: debe empezar y terminar con /
VITE_BASE=/mimi/

# URL de la API (opcional - se auto-detecta como {VITE_BASE}backend/api)
# Solo configurar si el backend esta en otra ubicacion:
# VITE_API_URL=https://api.tudominio.com/api
