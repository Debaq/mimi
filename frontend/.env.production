# URL base de la API PHP en produccion
# Ajustar segun donde este el backend en tu servidor
#
# Si el backend esta en la MISMA carpeta que el frontend (dist):
# VITE_API_URL=/api
#
# Si el backend esta en un subdirectorio:
# VITE_API_URL=/mimi/backend/api
#
# Si esta en otro dominio:
# VITE_API_URL=https://api.tudominio.com/api
VITE_API_URL=/api
